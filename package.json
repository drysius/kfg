{
  "name": "kfg",
  "type": "module",
  "description": "Powerful, type-safe configuration system for Node.js, Bun, and Deno. Built on TypeBox with Laravel-style rules and smart environment tracing.",
  "version": "1.5.0",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drysius/kfg.git"
  },
  "keywords": [
    "config",
    "configuration",
    "settings",
    "type-safe",
    "typescript",
    "typebox",
    "validation",
    "schema",
    "env",
    "dot-env",
    "json",
    "laravel-rules",
    "tracing",
    "backend",
    "node",
    "bun",
    "deno",
    "performance"
  ],
  "author": "Drysius",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/drysius/kfg/issues"
  },
  "homepage": "https://kfg.js.org",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.test.json && bun run build.ts",
    "docs": "typedoc",
    "test": "bun test",
    "check": "biome check --write",
    "llms": "bun llms.ts",
    "typecheck": "tsc --noEmit",
    "prebuild": "tsc --project tsconfig.test.json"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@types/bun": "^1.3.6",
    "@types/node": "^25.0.9",
    "dts-bundle-generator": "^9.5.1",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.47"
  }
}
